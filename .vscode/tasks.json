{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build requirements PDF",
      "type": "process",
      "command": "python",
      "args": [
        "scripts/build-requirements-pdf.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "detail": "Builds build/requirements.pdf from requirements/*.md."
    }
  ]
}
